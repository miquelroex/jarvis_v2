# ═══════════════════════════════════════════
# Variables de entorno para Jarvis (.env.example)
# Copia este archivo como .env y rellena tus claves.
# ═══════════════════════════════════════════

# OpenRouter API Key
OPENROUTER_API_KEY=tu_clave_openrouter_aqui

# ElevenLabs API Key
# Para clonar la voz de JARVIS (Paul Bettany): sube 1-2 min de audio limpio a
# https://elevenlabs.io/app/voice-lab -> Instant Voice Cloning y pega el ID aquí.
ELEVENLABS_API_KEY=tu_clave_elevenlabs_aqui
ELEVENLABS_VOICE_ID=tu_voice_id_aqui

# Google AI Studio / Gemini
GOOGLE_API_KEY=tu_clave_google_aqui

# Modelos Jarvis
JARVIS_MODEL_DEFAULT=deepseek/deepseek-v4-pro
JARVIS_MODEL_THINK=gemini-3.5-flash
JARVIS_THINK_PROVIDER=google_ai_studio
JARVIS_MODEL_GEMINI=gemini-3.5-flash
# Protocolo Babel (traducción en vivo): modelo usado para traducir por voz/Telegram
# ("traduce al inglés ..." o /translate). Si se deja vacío usa JARVIS_MODEL_THINK
# y, en su defecto, el modelo por defecto.
JARVIS_MODEL_TRANSLATE=

# Protocolo "Mente Colmena" (consenso multi-modelo): al decir "mente colmena
# <pregunta>", Jarvis consulta a varios modelos en paralelo y sintetiza un
# consenso. Lista de modelos (OpenRouter) separada por comas; si se deja vacía,
# usa los modelos configurados (default/think/code). El sintetizador por defecto
# es JARVIS_MODEL_DEFAULT (o JARVIS_HIVE_SYNTHESIZER).
JARVIS_HIVE_MODELS=
JARVIS_HIVE_SYNTHESIZER=

# Protocolo "Casa Llena" (multi-agente): al decir "casa llena <objetivo>", Jarvis
# despliega un equipo de agentes con roles (investigación, ingeniería, control de
# calidad) que aportan en paralelo y un coordinador unifica. Cada rol usa su modelo
# (JARVIS_MODEL_THINK/CODE); el coordinador es JARVIS_HOUSEPARTY_COORDINATOR o el default.
JARVIS_HOUSEPARTY_COORDINATOR=

# Protocolo "Mark II" (auto-mejora supervisada): "protocolo mark dos <fichero>:
# <mejora>". Jarvis reescribe ese fichero en una RAMA AISLADA, corre los tests y
# sólo deja el commit si pasan (nunca toca tu rama, nunca hace push/merge). Por
# seguridad sólo puede editar ficheros dentro de estas carpetas (allowlist):
JARVIS_MARKII_ALLOWED_DIRS=core,tools
# Comando de validación (por defecto la suite completa):
JARVIS_MARKII_TEST_CMD=python -m pytest -q
JARVIS_MODEL_CODE=anthropic/claude-sonnet-4.6
JARVIS_MODEL_AGENT=minimax/minimax-m2.7
JARVIS_MODEL_PRO=openai/gpt-5.5
JARVIS_MODEL_ULTRA=openai/gpt-5.5-pro
JARVIS_REQUIRE_CONFIRM_PRO=true
JARVIS_REQUIRE_CONFIRM_ULTRA=true

# TAVILY API Key
TAVILY_API_KEY=tu_clave_tavily_aqui

# Memoria semántica (RAG): indexa los recuerdos con embeddings de Google para
# buscarlos por significado. Requiere GOOGLE_API_KEY. Al activarlo, los textos
# de tus recuerdos se envían a Google para generar el embedding. Off por defecto.
JARVIS_SEMANTIC_MEMORY_ENABLED=false
JARVIS_EMBEDDING_MODEL=text-embedding-004

# Project Awareness: carpeta base donde tienes tus repos. Si se define, Jarvis
# intenta detectar el proyecto del editor activo; si no, usa su propio repo.
# Ejemplo: JARVIS_PROJECTS_DIR=C:\Users\miquel
JARVIS_PROJECTS_DIR=

# Mapbox (mapa/globo 3D del mundo). Token público "pk...." de mapbox.com (gratis).
# Necesario para abrir el mapa y volar a lugares por voz ("llévame a Tokio").
MAPBOX_TOKEN=
JARVIS_MAP_FLY_ZOOM=9

# OpenWeatherMap (para el briefing matutino). Deja vacío para omitir el clima.
# Se acepta cualquiera de los dos nombres: OPENWEATHER_API_KEY u OPENWEATHERMAP_API_KEY.
# IMPORTANTE: define también JARVIS_WEATHER_CITY o no se mostrará el clima.
# Ciudad en formato "Ciudad,CODIGOPAIS" (p.ej. Madrid,ES).
OPENWEATHER_API_KEY=tu_clave_openweather_aqui
JARVIS_WEATHER_CITY=Madrid,ES
JARVIS_WEATHER_UNITS=metric
JARVIS_WEATHER_LANG=es

# Voice Activity Detection (VAD)
JARVIS_VAD_ENABLED=True
JARVIS_VAD_MULTIPLIER=3.0
JARVIS_VAD_MIN_THRESHOLD=700.0
JARVIS_VAD_CONSECUTIVE_FRAMES=4

# Modo Conversación Continua (manos libres): tras CUALQUIER comando, Jarvis sigue
# escuchando sin que repitas "Jarvis", para encadenar órdenes; vuelve al modo
# palabra de activación tras JARVIS_CONVERSATION_TIMEOUT segundos de silencio.
JARVIS_CONTINUOUS_MODE=false
JARVIS_CONVERSATION_TIMEOUT=10

# Speech Recognition (ASR / STT)
JARVIS_ASR_PAUSE_THRESHOLD=1.4
JARVIS_ASR_DYNAMIC_THRESHOLD=True
JARVIS_ASR_ENERGY_THRESHOLD=300.0

# Whisper STT (faster-whisper con CUDA)
# Engine: "whisper" usa Whisper local, "google" usa Google Web Speech API
JARVIS_STT_ENGINE=whisper
# Modelos disponibles: tiny, base, small, medium, large-v3
# small = buen balance; medium = mayor precisión; large-v3 = máxima precisión
JARVIS_WHISPER_MODEL=small
# Dispositivo: auto (usa GPU si disponible), cpu, cuda
JARVIS_WHISPER_DEVICE=auto
# Idioma forzado (evita detección automática, mejora precisión)
JARVIS_WHISPER_LANGUAGE=es

# Telegram Remote Control Bot
TELEGRAM_BOT_TOKEN=tu_token_telegram_aqui
TELEGRAM_USER_ID=tu_user_id_aqui
# Chat conversacional por Telegram: escribe en lenguaje natural o envía notas de
# voz (Jarvis las transcribe con Whisper) y te responde. Si VOICE_REPLY está
# activo, Jarvis adjunta su respuesta también como audio con su voz (a las notas
# de voz responde con voz siempre). Cámbialo en caliente con /voicereply on|off.
JARVIS_TELEGRAM_VOICE_REPLY=true

# Error Auto-Fixer
JARVIS_ERROR_AUTOFIX_ENABLED=True

# Privacy Scan
JARVIS_PRIVACY_SCAN_INTERVAL=900

# Push Notifications (ntfy.sh)
JARVIS_NTFY_TOPIC=jarvis_notifications_tu_nombre

# GUI Config
# Clave de sesión de Flask. Genera un valor aleatorio propio, por ejemplo:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Si se deja vacía, Jarvis genera una clave aleatoria nueva en cada arranque.
JARVIS_SECRET_KEY=

# Test Watcher Config
JARVIS_TEST_WATCHER=false

# Service Toggles (Modo Seguro: poner todo a false)
# Servicios de uso diario: activados por defecto
JARVIS_GUI_ENABLED=true
JARVIS_TELEGRAM_ENABLED=true
JARVIS_SCHEDULER=true
JARVIS_SENTINEL_ENABLED=true
JARVIS_NETWORK_SCAN_WORKERS=20
# Servicios pesados (auditorías periódicas, suite de tests cada 20 min):
# desactivados por defecto; actívalos solo cuando los necesites.
JARVIS_API_SENTINEL_ENABLED=false
JARVIS_VULNERABILITY_PATCHER_ENABLED=false
JARVIS_PATCHER_ENABLED=false
JARVIS_INTEGRITY_SENTINEL_ENABLED=false

# Auditoría proactiva de salud de dependencias (PyPI: outdated / abandonadas)
JARVIS_DEP_HEALTH_ENABLED=false
JARVIS_DEP_STALE_DAYS=540
JARVIS_DEP_HEALTH_INTERVAL=86400

# Resumen diario programado (Daily Digest nocturno) — voz y/o Telegram
JARVIS_DAILY_DIGEST_ENABLED=false
JARVIS_DAILY_DIGEST_HOUR=22
JARVIS_DAILY_DIGEST_CHANNEL=both

# JARVIS Proactivo Visual: cada X seg captura la pantalla y la analiza con
# Gemini Vision para avisarte por voz si detecta algo relevante.
# ⚠️ Envía capturas de pantalla a Google (Gemini). Desactivado por defecto.
JARVIS_PROACTIVE_VISION_ENABLED=false
JARVIS_PROACTIVE_VISION_INTERVAL=300

# Protocolo "Mayordomo": al decir "buenos días Jarvis" / "protocolo mayordomo",
# prepara tu estación abriendo estas apps y URLs, y te da el parte del día
# (reutiliza el briefing matutino: clima, git, recordatorios). Listas separadas
# por comas. Ejemplo: JARVIS_BUTLER_APPS=code,spotify  JARVIS_BUTLER_URLS=https://github.com
JARVIS_BUTLER_APPS=
JARVIS_BUTLER_URLS=

# Briefing matutino (clima, git, recordatorios de hoy)
# Opción A: programado a una hora concreta (daemon).
JARVIS_MORNING_BRIEFING_ENABLED=false
JARVIS_MORNING_BRIEFING_HOUR=8
JARVIS_MORNING_CHANNEL=both
# Opción B: que lo diga por voz al arrancar Jarvis (en vez de a una hora fija).
JARVIS_MORNING_BRIEFING_ON_STARTUP=false

# Mantenimiento de logs y temporales (limpieza automática segura)
JARVIS_LOG_MAINTENANCE_ENABLED=true
JARVIS_LOG_MAINTENANCE_INTERVAL=21600
JARVIS_AUDIO_TEMP_MAX_AGE_HOURS=24
JARVIS_BACKUP_RETENTION_DAYS=30
JARVIS_BACKUP_MAX_MB=200
JARVIS_LOG_RETENTION_DAYS=14
JARVIS_LOG_MAX_MB=10

# RAM Guard
JARVIS_MAX_RAM_MB=2500
JARVIS_MAX_SYSTEM_RAM_PERCENT=90
JARVIS_AUTO_SAFE_MODE_ON_HIGH_RAM=true

# ─────────────────────────────────────────────
# Personalidad y Voz de JARVIS
# ─────────────────────────────────────────────

# Voz del motor Edge-TTS (gratuito, no requiere API Key)
# Opciones recomendadas (masculinas, graves):
#   es-ES-AlvaroNeural  → voz española estándar (defecto)
#   es-ES-PabloNeural   → voz más grave y pausada
# Lista completa: python -m edge_tts --list-voices | Select-String "es-"
JARVIS_EDGE_TTS_VOICE=es-ES-AlvaroNeural

# Voz adaptativa (Tone Shifting): Jarvis ajusta automáticamente velocidad/pitch
# (Edge-TTS) y estabilidad/estilo (ElevenLabs) según el contexto de cada frase:
# sereno al informar, firme y rápido en alertas, pausado y grave de noche,
# brillante al confirmar un éxito y juguetón en la ironía. Pon "false" para usar
# siempre un tono neutro. Ver core/voice_tone.py.
JARVIS_VOICE_ADAPTIVE_ENABLED=true

# Reacciones con Alma: Jarvis muestra emoción contenida ante eventos (alivio
# cuando unas pruebas vuelven a pasar tras fallar, urgencia medida en alertas,
# orgullo seco en un resultado impecable) y colorea sus respuestas con ese matiz.
JARVIS_REACTIONS_ENABLED=true

# Stream de Pensamiento: en tareas largas (Mark II, Mente Colmena, Casa Llena…),
# Jarvis narra lo que va haciendo paso a paso. En el HUD siempre; por voz solo si
# JARVIS_NARRATION_VOICE=true (puede ser locuaz).
JARVIS_NARRATION_ENABLED=true
JARVIS_NARRATION_VOICE=false

# Anuncios de notificaciones entrantes: banner dramático en la GUI (p. ej. al
# recibir un mensaje por Telegram). Por voz solo si JARVIS_ANNOUNCE_VOICE=true.
JARVIS_ANNOUNCE_ENABLED=true
JARVIS_ANNOUNCE_VOICE=false

# Núcleo Holográfico reactivo a la voz: mientras Jarvis habla, la esfera central
# de la GUI pulsa con la amplitud real del audio (lip-sync por energía). El
# backend calcula la envolvente del audio sintetizado y la transmite por socket;
# si no se puede, la GUI usa un pulso sintético. Pon "false" para desactivarlo.
JARVIS_VOICE_CORE_ENABLED=true
JARVIS_VOICE_CORE_FPS=30

# Protocolo Blackout (modo noche): pasada cierta hora, Jarvis atenúa la GUI en
# tonos cálidos y, una vez por noche, te sugiere descansar con voz suave.
# Franja por defecto 00:00–07:00. Para una franja que cruce la medianoche, pon
# START_HOUR mayor que END_HOUR (p.ej. 23 y 7 → de 23:00 a 07:00). Off por defecto.
JARVIS_BLACKOUT_ENABLED=false
JARVIS_BLACKOUT_START_HOUR=0
JARVIS_BLACKOUT_END_HOUR=7
JARVIS_BLACKOUT_CHECK_INTERVAL=300
# Opcional: al entrar en modo noche, bajar el volumen del sistema.
JARVIS_BLACKOUT_LOWER_VOLUME=false
JARVIS_BLACKOUT_VOLUME=30

# HUD Overlay flotante: ventana de escritorio sin bordes, semitransparente y
# siempre encima (estilo casco de Iron Man) con telemetría en vivo (RAM/CPU,
# servicios, hora, DEFCON, último comando). Arrástrala con el ratón; Esc la
# cierra. También por voz: "abre el HUD" / "cierra el HUD". Off por defecto.
JARVIS_HUD_OVERLAY_ENABLED=false
JARVIS_HUD_ALPHA=0.86

# Protocolo Verónica (modo enfoque): por voz ("activa el protocolo Verónica" o
# "modo enfoque 50 minutos") silencia las notificaciones toast de Windows, tiñe
# la GUI en ámbar de alto contraste y muestra un temporizador de cuenta atrás
# que, al expirar, restaura todo. JARVIS_FOCUS_MUTE_NOTIFICATIONS controla el
# silenciado de notificaciones (registro ToastEnabled, reversible).
JARVIS_FOCUS_DEFAULT_MINUTES=25
JARVIS_FOCUS_MUTE_NOTIFICATIONS=true

# Telemetría térmica de hardware (mapa de calor 3D en la GUI): muestra la carga
# real por núcleo de la CPU en un grid 3D (azul=ocioso, rojo=saturado) más CPU/
# RAM y, si el sistema lo expone, temperatura y batería. Ábrelo por voz ("abre el
# mapa de calor") o di "cierra el mapa de calor". Ligero; on por defecto.
JARVIS_THERMAL_TELEMETRY_ENABLED=true
JARVIS_THERMAL_INTERVAL=3

# Packet Map 3D (telemetría de red): muestra en 3D las conexiones activas de tu
# PC a endpoints remotos (IPs/puertos a los que se conectan tus apps), vía
# psutil.net_connections. Ábrelo por voz ("mapa de paquetes" / "telemetría de
# red"). Es distinto del Radar de Red (dispositivos en tu LAN). On por defecto.
JARVIS_PACKET_MAP_ENABLED=true
JARVIS_PACKET_MAP_INTERVAL=6

# Anticipación: Jarvis aprende tus rutinas (qué apps/webs abres a cada hora) y, si
# detecta un patrón fuerte, te sugiere por voz adelantarse. Off por defecto porque
# interrumpe con voz. Registro local en logs/anticipation_log.jsonl.
# Pregúntale en cualquier momento: "Jarvis, ¿qué suelo hacer ahora?".
JARVIS_ANTICIPATION_ENABLED=false
JARVIS_ANTICIPATION_INTERVAL=1800

# Rastreador de Productividad: mide cuánto tiempo dedicas a cada proyecto/actividad
# muestreando la ventana activa (y el repo git si es un editor); ignora el tiempo
# AFK. Todo local (logs/productivity/). Pregúntale "¿cuánto he trabajado hoy?".
# Off por defecto (registra tu actividad). Intervalo de muestreo e idle en segundos.
JARVIS_PRODUCTIVITY_ENABLED=false
JARVIS_PRODUCTIVITY_INTERVAL=30
JARVIS_PRODUCTIVITY_IDLE_THRESHOLD=300

# Insight Proactivo ("Señor, detecto un patrón"): cruza tus hábitos registrados
# (anticipación) y la base de errores recurrentes, y cuando encuentra algo
# significativo (un día de la semana dominante, tu pico de actividad, una
# secuencia A->B recurrente o un error reincidente) lo comenta con un toque
# Stark. Entrega como mucho un insight al día. HUD siempre; voz opcional.
# Pregúntale en cualquier momento: "Jarvis, ¿detectas algún patrón?".
JARVIS_INSIGHTS_ENABLED=false
JARVIS_INSIGHTS_VOICE=false
JARVIS_INSIGHTS_INTERVAL=3600

# Memoria de Sesión con Callbacks: Jarvis recuerda los turnos de los últimos
# minutos (buffer en memoria, no se guarda en disco) y enlaza de forma natural
# cuando retomas un tema ya tratado: "Como mencionó antes, señor, sobre el
# módulo de red…". Sólo enriquece respuestas del agente (no comandos rápidos).
# Pregúntale "¿de qué hemos hablado?". On por defecto (es sólo texto, sin coste).
# JARVIS_SESSION_WINDOW: ventana de relevancia en segundos.
JARVIS_SESSION_CALLBACKS=true
JARVIS_SESSION_WINDOW=600

# Puesto de Vigilancia ("Jarvis, vigila esto"): pones un fichero, proceso o
# puerto bajo vigilancia y Jarvis avisa en cuanto cambie su estado (modificado,
# desaparecido, proceso parado/arrancado, puerto abierto/cerrado). Las
# vigilancias se añaden por voz ("vigila el fichero config.py") y arrancan el
# sondeo bajo demanda; esta variable sólo pre-arranca el daemon vacío al inicio.
# JARVIS_WATCHPOST_INTERVAL: segundos entre sondeos.
JARVIS_WATCHPOST_ENABLED=false
JARVIS_WATCHPOST_INTERVAL=20

# Análisis con Retícula ("escanea esto"): captura la pantalla, la analiza con
# Gemini Vision (requiere GOOGLE_API_KEY) y dibuja retículas/cajas de combate
# sobre el escritorio real (overlay tkinter transparente), narrando lo
# detectado. Bajo demanda por voz ("escanea esto"); no hay daemon.
# JARVIS_RETICLE_OVERLAY: dibujar el overlay de escritorio (true) o sólo narrar.
# JARVIS_RETICLE_DURATION: segundos que permanecen las retículas en pantalla.
JARVIS_RETICLE_OVERLAY=true
JARVIS_RETICLE_DURATION=5

# Cerebro de Estado Central (Modelo de Mundo): unifica el estado vivo de todos
# los dominios (sistema, servicios, amenaza, proyecto, productividad, red,
# vigilancias, uso de IA) en un único snapshot que se inyecta en el contexto del
# agente (conciencia situacional en cada turno) y alimenta el informe de
# situación por voz ("informe de situación"). JARVIS_WORLD_MODEL_TTL: segundos
# que se cachea el snapshot para no recalcularlo en cada turno.
JARVIS_WORLD_MODEL_TTL=8

# Iniciativa Ejecutora (proactividad con criterio): sobre el Cerebro de Estado
# Central, compara el mundo entre sondeos y, según el nivel de confianza, avisa
# o actúa por su cuenta en lo de bajo riesgo ("me he tomado la libertad…").
#   off    -> no hace nada (por defecto).
#   notify -> sólo avisa de cambios significativos; nunca ejecuta.
#   act    -> además autoejecuta acciones SAFE (p.ej. liberar memoria) y avisa;
#             lo arriesgado siempre lo consulta, nunca lo hace solo.
# Por voz: "toma la iniciativa" (act), "sólo avísame" (notify), "desactiva la
# iniciativa" (off). VOICE: si además habla el aviso (HUD siempre).
# COOLDOWN: segundos mínimos entre repeticiones de la misma iniciativa.
JARVIS_INITIATIVE_LEVEL=off
JARVIS_INITIATIVE_VOICE=false
JARVIS_INITIATIVE_INTERVAL=60
JARVIS_INITIATIVE_COOLDOWN=600

# Motor de Fusión de Fuentes ("lo sabe todo"): ante una pregunta, Jarvis
# consulta varias fuentes a la vez (web vía Tavily/DuckDuckGo, clima, su propio
# estado interno) y un modelo sintetiza UNA respuesta con criterio cruzando lo
# que dicen. Por voz: "fusiona <pregunta>", "analiza a fondo <pregunta>", "con
# todo lo que sabes <pregunta>". Cada fuente degrada con gracia si no está
# configurada. JARVIS_FUSION_TIMEOUT: segundos máx. esperando a las fuentes.
JARVIS_FUSION_TIMEOUT=12

# Datos del Mundo en Vivo: conecta a Jarvis con datos reales y actuales usando
# APIs públicas SIN clave — cripto (CoinGecko), sismos (USGS) y tech-news (Hacker
# News). Se exponen por voz ("precio del bitcoin", "últimos terremotos",
# "noticias de tecnología") y como fuente del Motor de Fusión con relevancia por
# tema (sólo se consulta lo que la pregunta menciona). No requiere configuración.

# Vigilancia Proactiva del Mundo: como el Puesto de Vigilancia pero apuntando al
# mundo. Registras qué seguir por voz ("vigila el bitcoin", "avísame de
# terremotos") y un daemon sondea los datos en vivo y avisa SIN preguntar cuando
# hay un cambio relevante ("Bitcoin ha caído un 5%", "sismo de magnitud 6"). El
# daemon arranca bajo demanda al añadir la primera vigilancia; esta variable sólo
# lo pre-arranca al inicio. THRESHOLD: % de variación cripto para avisar.
# QUAKE_MAG: magnitud mínima de sismo. INTERVAL: segundos entre sondeos.
JARVIS_WORLDWATCH_ENABLED=false
JARVIS_WORLDWATCH_CRYPTO_THRESHOLD=5
JARVIS_WORLDWATCH_QUAKE_MAG=5
JARVIS_WORLDWATCH_INTERVAL=300

# Investigador Autónomo Profundo: "investiga X" → Jarvis descompone la pregunta
# en sub-preguntas, investiga cada una en la web (en paralelo, reusa la fuente
# web del motor de fusión), contrasta y entrega un informe estructurado con
# conclusión. Por voz: "investiga <tema>", "investiga a fondo <tema>",
# "investigación profunda sobre <tema>". Requiere búsqueda web (Tavily o
# DuckDuckGo) y un modelo para planificar y redactar; degrada con gracia.

# Smart Lock por proximidad Bluetooth: cuando tu móvil/reloj se aleja (su señal
# BLE desaparece o cae bajo el umbral durante varios escaneos), Jarvis bloquea
# Windows; al volver, te da la bienvenida. Identifica el dispositivo por MAC BLE
# o por nombre (JARVIS_SMART_LOCK_NAME, p.ej. "Galaxy Watch"). Nota: muchos
# móviles rotan su MAC BLE por privacidad; en ese caso usa el nombre o un reloj/
# pulsera. RSSI más alto (cercano a 0) = más cerca; -85 ≈ lejos. Off por defecto.
JARVIS_SMART_LOCK_ENABLED=false
JARVIS_SMART_LOCK_MAC=
JARVIS_SMART_LOCK_NAME=
JARVIS_SMART_LOCK_RSSI_THRESHOLD=-85
JARVIS_SMART_LOCK_ABSENT_SCANS=3
JARVIS_SMART_LOCK_INTERVAL=20
JARVIS_SMART_LOCK_SCAN_TIMEOUT=6

# Autodetector de Presencia: MAC address del móvil del usuario.
# Cuando el centinela de red detecta esta MAC en la Wi-Fi, Jarvis te saluda.
# Ejemplo: JARVIS_PRESENCE_MAC=aa:bb:cc:dd:ee:ff
# Deja vacío para desactivar el autodetector de presencia.
JARVIS_PRESENCE_MAC=
